{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://github.com/theb0yys/FOA-SDK/blob/main/Installer/SuiteWizard/ViewModel/confirmation.schema.json","title":"FOA-SDK installer wizard review confirmation","type":"object","additionalProperties":false,"required":["schema_version","confirmation_scope","plan_sha256","view_model_sha256","acknowledged_ids","confirmed_by","confirmed_at_utc","statement","authority","confirmation_sha256"],"properties":{"schema_version":{"const":1},"confirmation_scope":{"const":"review-only"},"plan_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"view_model_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"acknowledged_ids":{"type":"array","uniqueItems":true,"items":{"type":"string","pattern":"^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$","maxLength":128}},"confirmed_by":{"type":"string","minLength":1,"maxLength":160},"confirmed_at_utc":{"type":"string","format":"date-time"},"statement":{"const":"I reviewed the exact FOA-SDK installer plan and understand that this confirmation grants no acquisition, installation, elevation, launch, deployment, save-mutation, signing, publication, catalog-mutation, or evidence-promotion authority."},"authority":{"type":"object","additionalProperties":false,"required":["acquisition","installation","elevation","game_launch","runtime_execution","deployment","save_mutation","signing","publication","catalog_mutation","evidence_promotion"],"properties":{"acquisition":{"const":false},"installation":{"const":false},"elevation":{"const":false},"game_launch":{"const":false},"runtime_execution":{"const":false},"deployment":{"const":false},"save_mutation":{"const":false},"signing":{"const":false},"publication":{"const":false},"catalog_mutation":{"const":false},"evidence_promotion":{"const":false}}},"confirmation_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}}}
